<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) requires this file when android:dataExtractionRules
    is declared in the manifest. It controls what data is backed up to the cloud
    and transferred during device-to-device migration.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Back up app preferences and databases -->
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
        <!-- Exclude cache and temp files -->
        <exclude domain="cache" path="." />
        <exclude domain="external-cache" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
        <exclude domain="cache" path="." />
        <exclude domain="external-cache" path="." />
    </device-transfer>
</data-extraction-rules>
