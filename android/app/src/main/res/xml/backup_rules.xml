<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 11 and below uses this file when android:fullBackupContent is set.
    Newer devices use data_extraction_rules.xml instead, but this file must
    still exist or the build will fail.
-->
<full-backup-content>
    <include domain="sharedpref" path="." />
    <include domain="database" path="." />
    <exclude domain="cache" path="." />
    <exclude domain="external-cache" path="." />
</full-backup-content>
